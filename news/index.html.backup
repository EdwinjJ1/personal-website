  </div>

  <nav class="mobile-nav">
    <div class="mobile-nav-item active" data-filter="all"><span>Overview</span></div>
    <div class="mobile-nav-item" data-filter="ai"><span>AI</span></div>
    <div class="mobile-nav-item" data-filter="research"><span>Research</span></div>
    <div class="mobile-nav-item" data-filter="industry"><span>Industry</span></div>
    <div class="mobile-nav-item" data-filter="global"><span>Global</span></div>
  </nav>

  <script>
    // Available dates (would be populated by backend in production)
    const availableDates = ['2026-02-28', '2026-02-27', '2026-02-26', '2026-02-25', '2026-02-24'];
    let currentDate = '2026-02-28';

    function updateTime() {
      const now = new Date();
      document.getElementById('time').textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
      document.getElementById('date').textContent = now.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
    }
    updateTime();
    setInterval(updateTime, 1000);

    function toggle(header) { header.closest('.card').classList.toggle('expanded'); }

    function filter(type) {
      document.querySelectorAll('.nav-item, .mobile-nav-item').forEach(el => el.classList.toggle('active', el.dataset.filter === type));

      let visibleCount = 0;
      document.querySelectorAll('.card').forEach(card => {
        const cardDate = card.dataset.date;
        const cardType = card.dataset.type;
        const dateMatch = cardDate === currentDate;
        const typeMatch = type === 'all' || cardType === type;
        const shouldShow = dateMatch && typeMatch;
        card.style.display = shouldShow ? 'block' : 'none';
        if (shouldShow) visibleCount++;
      });

      // Handle empty state
      const cardsContainer = document.getElementById('cards');
      let emptyState = document.getElementById('emptyState');
      if (visibleCount === 0) {
        if (!emptyState) {
          emptyState = document.createElement('div');
          emptyState.id = 'emptyState';
          emptyState.style.cssText = 'text-align:center;padding:48px;color:var(--fg-muted);font-size:15px;';
          emptyState.textContent = '📭 No news available for this date';
          cardsContainer.appendChild(emptyState);
        }
      } else if (emptyState) {
        emptyState.remove();
      }
    }

    function selectDate(date) {
      currentDate = date;
      // Update active button
      document.querySelectorAll('.date-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.date === date);
      });
      // Update header title
      const today = new Date().toISOString().split('T')[0];
      const titleEl = document.querySelector('.title');
      if (date === today) {
        titleEl.textContent = 'Today';
      } else {
        const d = new Date(date);
        titleEl.textContent = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }
      // Re-filter cards
      const currentFilter = document.querySelector('.nav-item.active')?.dataset.filter || 'all';
      filter(currentFilter);
    }

    function initDateNav() {
      const container = document.getElementById('dateNav');
      const monthLabel = document.getElementById('monthLabel');
      const today = new Date().toISOString().split('T')[0];

      // Update month label based on current selection
      function updateMonthLabel(date) {
        const d = new Date(date);
        monthLabel.textContent = d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
      }

      availableDates.forEach(date => {
        const btn = document.createElement('button');
        btn.className = 'date-btn';
        btn.dataset.date = date;

        const d = new Date(date);
        const dayName = date === today ? 'Today' : d.toLocaleDateString('en-US', { weekday: 'short' });
        const dayNum = d.getDate();

        // Use textContent for security instead of innerHTML
        const span1 = document.createElement('span');
        span1.style.fontSize = '11px';
        span1.style.display = 'block';
        span1.textContent = dayName;

        const span2 = document.createElement('span');
        span2.style.fontSize = '14px';
        span2.textContent = dayNum;

        btn.appendChild(span1);
        btn.appendChild(span2);

        if (date === today) btn.classList.add('today');
        if (date === currentDate) btn.classList.add('active');

        btn.addEventListener('click', () => {
          selectDate(date);
          updateMonthLabel(date);
        });
        container.appendChild(btn);
      });

      updateMonthLabel(currentDate);
    }

    // Initialize
    document.querySelectorAll('.nav-item, .mobile-nav-item').forEach(el => el.addEventListener('click', () => filter(el.dataset.filter)));
    initDateNav();
  </script>
</body>
</html>
